#!/usr/bin/env bash
# repo-report: scan nested git repositories in parallel and report
#              branch / HEAD / dirty / ahead-behind / up-to-date status.
#
# Two modes:
#   - Interactive TUI (default on a TTY): animated "news ticker" reporter
#     at the top, streaming results, filter/fetch/rescan/quit keys.
#   - Non-interactive (--format, --non-interactive, or piped stdout):
#     table / TSV / JSON for pipelines and CI.
#
# Dependencies: bash >= 4, git, find, xargs, awk, mkfifo. `column` optional.

set -uo pipefail

VERSION="0.2.0"
ROOT="."
JOBS="$(nproc 2>/dev/null || echo 4)"
FETCH=0
FORMAT=""
NON_INTERACTIVE=0
MAX_DEPTH=""
MSG_WIDTH=60
ERR_DOC_URL="https://github.com/nigoh/repo_report/blob/main/docs/errors.md"

# ------------------------------------------------------------------
# Error helper: numbered RRxxx codes. All user-visible errors go
# through this so format stays consistent.
#   err CODE "message" [exit_status]
# ------------------------------------------------------------------
err() {
  local code="$1" msg="$2" rc="${3:-1}"
  if [[ "${_TUI_ON:-0}" -eq 1 ]]; then _tui_teardown; fi
  printf 'repo-report: [%s] %s\n' "$code" "$msg" >&2
  printf '  -> see: %s#%s\n' "$ERR_DOC_URL" "$code" >&2
  exit "$rc"
}

usage() {
  cat <<EOF
repo-report v${VERSION}
  Scan a directory tree for git repositories and report their status
  in parallel. Interactive news-ticker TUI by default; machine-readable
  table / TSV / JSON for pipelines and CI.

Usage:
  repo-report [OPTIONS] [PATH]

Options:
  -j, --jobs N         Parallel workers (default: nproc = ${JOBS})
  -f, --fetch          git fetch each repo before reporting (network)
      --format FMT     Output format: table | tsv | json (forces non-interactive)
  -n, --non-interactive
                       Force non-interactive output (default format: tsv)
      --max-depth N    Limit find depth
      --msg-width N    Truncate commit message in table (default 60)
  -h, --help           Show this help
  -V, --version        Show version

Behavior:
  - TTY + no --format/-n  -> interactive TUI with animated LIVE ticker
  - piped / redirected    -> TSV
  - --format explicit     -> that format (non-interactive)

Interactive keys:
  j/k or arrows  move      /  filter       f  toggle fetch+rescan
  r  rescan      q  quit

Error codes: see ${ERR_DOC_URL}
EOF
}

# ------------------------------------------------------------------
# Argument parsing
# ------------------------------------------------------------------
while [[ $# -gt 0 ]]; do
  case "$1" in
    -j|--jobs)
      [[ "${2:-}" =~ ^[1-9][0-9]*$ ]] || err RR103 "--jobs must be a positive integer" 2
      JOBS="$2"; shift 2;;
    -f|--fetch)          FETCH=1; shift;;
    --format)
      case "${2:-}" in
        table|tsv|json) FORMAT="$2" ;;
        *) err RR102 "--format must be one of: table, tsv, json" 2 ;;
      esac
      shift 2;;
    -n|--non-interactive) NON_INTERACTIVE=1; shift;;
    --max-depth)
      [[ "${2:-}" =~ ^[1-9][0-9]*$ ]] || err RR104 "--max-depth must be a positive integer" 2
      MAX_DEPTH="$2"; shift 2;;
    --msg-width)
      [[ "${2:-}" =~ ^[1-9][0-9]*$ ]] || err RR104 "--msg-width must be a positive integer" 2
      MSG_WIDTH="$2"; shift 2;;
    -h|--help)           usage; exit 0;;
    -V|--version)        echo "$VERSION"; exit 0;;
    --)                  shift; ROOT="${1:-.}"; shift || true;;
    -*)                  err RR101 "unknown option: $1" 2;;
    *)                   ROOT="$1"; shift;;
  esac
done

# Dependency check
for bin in git find xargs awk; do
  command -v "$bin" >/dev/null 2>&1 || {
    case "$bin" in
      git) err RR301 "git binary not found on PATH" 127 ;;
      *)   err RR501 "required dependency missing: $bin" 127 ;;
    esac
  }
done

# Path check
[[ -e "$ROOT" ]] || err RR201 "path does not exist: $ROOT" 1
[[ -d "$ROOT" ]] || err RR201 "path is not a directory: $ROOT" 1
[[ -r "$ROOT" ]] || err RR202 "path is not readable: $ROOT" 1

# ------------------------------------------------------------------
# Discovery
# ------------------------------------------------------------------
scan_paths() {
  local find_opts=()
  [[ -n "$MAX_DEPTH" ]] && find_opts+=(-maxdepth "$MAX_DEPTH")
  find "$ROOT" "${find_opts[@]}" -name .git \( -type d -o -type f \) -prune 2>/dev/null | sort -u
}

mapfile -t GIT_PATHS < <(scan_paths)

if [[ ${#GIT_PATHS[@]} -eq 0 ]]; then
  printf 'repo-report: [RR203] no git repositories found under: %s\n' "$ROOT" >&2
  exit 0
fi

# ------------------------------------------------------------------
# Worker: one TSV line per repo. Writes < PIPE_BUF so xargs -P is
# atomic on stdout.
# ------------------------------------------------------------------
_report_one() {
  local gitpath="$1"
  local repo="${gitpath%/.git}"
  [[ -z "$repo" ]] && repo="."

  local branch sha date msg remote upstream ahead behind dirty status porcelain

  branch=$(git -C "$repo" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")
  [[ "$branch" == "HEAD" ]] && branch="(detached)"
  sha=$(git -C "$repo" rev-parse --short HEAD 2>/dev/null || echo "-")
  date=$(git -C "$repo" log -1 --format=%cI 2>/dev/null || echo "-")
  msg=$(git -C "$repo" log -1 --format=%s 2>/dev/null | tr '\t\r\n' '   ')
  remote=$(git -C "$repo" config --get remote.origin.url 2>/dev/null || echo "-")

  if [[ "${REPO_REPORT_FETCH:-0}" -eq 1 ]]; then
    git -C "$repo" fetch --quiet --all --prune 2>/dev/null || true
  fi

  upstream=$(git -C "$repo" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || echo "")
  ahead=0; behind=0
  if [[ -n "$upstream" ]]; then
    read -r ahead behind < <(git -C "$repo" rev-list --left-right --count "HEAD...$upstream" 2>/dev/null) || { ahead=0; behind=0; }
  fi

  porcelain=$(git -C "$repo" status --porcelain 2>/dev/null || true)
  if [[ -n "$porcelain" ]]; then dirty="dirty"; else dirty="clean"; fi

  if [[ -z "$upstream" ]]; then status="no-upstream"
  elif [[ "$ahead" -eq 0 && "$behind" -eq 0 ]]; then status="up-to-date"
  elif [[ "$ahead" -gt 0 && "$behind" -gt 0 ]]; then status="diverged"
  elif [[ "$behind" -gt 0 ]]; then status="behind"
  else status="ahead"
  fi

  stash=$(git -C "$repo" stash list 2>/dev/null | wc -l | tr -d ' ')

  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$repo" "$branch" "$sha" "$date" "$ahead" "$behind" "$dirty" "$status" "$remote" "$msg" "$stash"
}
export -f _report_one
export REPO_REPORT_FETCH="$FETCH"

run_scan_sync() {
  printf '%s\0' "${GIT_PATHS[@]}" \
    | xargs -0 -n1 -P "$JOBS" bash -c '_report_one "$1"' bash \
    | sort
}

# ------------------------------------------------------------------
# Non-interactive emitters
# ------------------------------------------------------------------
emit_tsv() {
  printf 'repo\tbranch\tsha\tdate\tahead\tbehind\tdirty\tstatus\tremote\tmessage\tstash\n'
  printf '%s\n' "$1"
}

emit_table() {
  local w="$MSG_WIDTH"
  {
    printf 'REPO\tBRANCH\tSHA\tDATE\tA\tB\tDIRTY\tSTATUS\tMESSAGE\tSTASH\n'
    printf '%s\n' "$1" \
      | awk -F'\t' -v W="$w" 'BEGIN{OFS="\t"}
          { m=$10; if (length(m) > W) m=substr(m,1,W-1) "…";
            d=$4; if (length(d) >= 10) d=substr(d,1,10);
            print $1,$2,$3,d,$5,$6,$7,$8,m,$11+0 }'
  } | { command -v column >/dev/null 2>&1 && column -t -s $'\t' || cat; }
}

emit_json() {
  printf '%s\n' "$1" | awk -F'\t' '
    function esc(s,   r){ r=s;
      gsub(/\\/, "\\\\", r);
      gsub(/"/,  "\\\"", r);
      gsub(/\t/, "\\t",  r);
      gsub(/\n/, "\\n",  r);
      gsub(/\r/, "\\r",  r);
      return r
    }
    BEGIN{ print "["; first=1 }
    NF==0 { next }
    {
      if (!first) printf ",\n"; first=0
      printf "  {\"repo\":\"%s\",\"branch\":\"%s\",\"sha\":\"%s\",\"date\":\"%s\",\"ahead\":%d,\"behind\":%d,\"dirty\":\"%s\",\"status\":\"%s\",\"remote\":\"%s\",\"message\":\"%s\",\"stash\":%d}",
        esc($1), esc($2), esc($3), esc($4), $5+0, $6+0, esc($7), esc($8), esc($9), esc($10), $11+0
    }
    END{ if (!first) printf "\n"; print "]" }
  '
}

final_exit_code() {
  printf '%s\n' "$1" | awk -F'\t' '
    $7!="clean" || ($8!="up-to-date" && $8!="no-upstream") { bad=1 }
    END{ exit bad?1:0 }'
}

# ------------------------------------------------------------------
# Mode selection
# ------------------------------------------------------------------
WANT_INTERACTIVE=0
if [[ -n "$FORMAT" ]]; then
  WANT_INTERACTIVE=0
elif [[ "$NON_INTERACTIVE" -eq 1 ]]; then
  WANT_INTERACTIVE=0
  FORMAT="tsv"
elif [[ -t 1 ]]; then
  WANT_INTERACTIVE=1
else
  WANT_INTERACTIVE=0
  FORMAT="tsv"
fi

if [[ "$WANT_INTERACTIVE" -eq 0 ]]; then
  TSV=$(run_scan_sync)
  case "$FORMAT" in
    table) emit_table "$TSV" ;;
    tsv)   emit_tsv   "$TSV" ;;
    json)  emit_json  "$TSV" ;;
  esac
  if final_exit_code "$TSV"; then exit 0; else exit 1; fi
fi

# ==================================================================
# Interactive TUI
# ==================================================================

[[ -t 0 && -t 1 ]] || err RR401 "interactive mode requires a TTY" 2

TERM_ROWS=24; TERM_COLS=80
_query_size() {
  local sz
  if sz=$(stty size 2>/dev/null); then
    TERM_ROWS="${sz% *}"; TERM_COLS="${sz#* }"
  fi
  [[ "$TERM_ROWS" -ge 10 && "$TERM_COLS" -ge 20 ]] || err RR402 "terminal too small (need >= 20x10)" 2
}
_query_size

_TUI_ON=0
SCAN_PID=""
FIFO=""

_tui_setup() {
  printf '\e[?1049h\e[?25l'
  stty -echo -icanon time 0 min 0 2>/dev/null || true
  _TUI_ON=1
}
_tui_teardown() {
  [[ "${_TUI_ON:-0}" -eq 1 ]] || return 0
  _TUI_ON=0
  stty sane 2>/dev/null || true
  printf '\e[?25h\e[?1049l'
}
_cleanup() {
  if [[ -n "$SCAN_PID" ]]; then
    kill "$SCAN_PID" 2>/dev/null || true
    wait "$SCAN_PID" 2>/dev/null || true
  fi
  exec 3<&- 2>/dev/null || true
  [[ -n "$FIFO" && -e "$FIFO" ]] && rm -f "$FIFO"
  _tui_teardown
}
trap _cleanup EXIT
trap 'RESIZE=1' WINCH
trap 'exit 130' INT TERM

RESIZE=0
declare -a ROWS=()
declare -a VIEW=()
SELECTED=0
SCROLL=0
FILTER=""
SCANNED=0
TOTAL="${#GIT_PATHS[@]}"
BEHIND_N=0
DIRTY_N=0
DIVERGED_N=0
AHEAD_N=0
TICKER_BUF=""
TICKER_OFFSET=0
BREAKING=""
SORT_MODE="path"
declare -a SORT_MODES=("path" "status" "date" "branch" "ahead-desc" "behind-desc")
SORT_IDX=0
FILTER_MODE=0
FILTER_SAVED=""
FILTER_INPUT=""
SHOW_HEADER=0
IS_REPO_WS=0
[[ -d "${ROOT}/.repo" ]] && IS_REPO_WS=1
REPO_MANIFEST_BRANCH=""
if [[ "$IS_REPO_WS" -eq 1 ]]; then
  REPO_MANIFEST_BRANCH=$(repo info -l 2>/dev/null | awk '/Manifest branch/{print $NF}' || echo "")
fi

_add_breaking() {
  BREAKING="$BREAKING   $1"
  # keep last ~200 chars
  [[ "${#BREAKING}" -gt 200 ]] && BREAKING="${BREAKING: -200}"
}

_ticker_rebuild() {
  local p="   🔴 LIVE  ·  REPO REPORTER  ·  scanned ${SCANNED}/${TOTAL}"
  [[ "$BEHIND_N"   -gt 0 ]] && p+="  ·  ⚡ ${BEHIND_N} BEHIND"
  [[ "$DIVERGED_N" -gt 0 ]] && p+="  ·  ⚡ ${DIVERGED_N} DIVERGED"
  [[ "$AHEAD_N"    -gt 0 ]] && p+="  ·  ⚡ ${AHEAD_N} AHEAD"
  [[ "$DIRTY_N"    -gt 0 ]] && p+="  ·  ⚠ ${DIRTY_N} DIRTY"
  [[ -n "$BREAKING" ]]     && p+="  ·  $BREAKING"
  p+="   ·   press ? for help, q to quit   ·   "
  p+="                              "
  TICKER_BUF="$p"
}

_draw_ticker() {
  _ticker_rebuild
  local len="${#TICKER_BUF}"
  [[ "$len" -lt 1 ]] && return
  local doubled="${TICKER_BUF}${TICKER_BUF}"
  local off=$(( TICKER_OFFSET % len ))
  local slice="${doubled:off:TERM_COLS}"
  printf '\e[1;1H\e[2K\e[7m%s\e[0m' "$slice"
}

_draw_status() {
  local fetch_str="off"; [[ "$FETCH" -eq 1 ]] && fetch_str="on"
  printf '\e[2;1H\e[2K'
  local status_line
  status_line=$(printf 'root:%s  jobs:%d  fetch:%s  sort:%s  scanned:%d/%d  behind:%d  ahead:%d  dirty:%d  diverged:%d  filter:%s' \
    "$ROOT" "$JOBS" "$fetch_str" "$SORT_MODE" "$SCANNED" "$TOTAL" "$BEHIND_N" "$AHEAD_N" "$DIRTY_N" "$DIVERGED_N" "${FILTER:--}")
  if [[ "$IS_REPO_WS" -eq 1 ]]; then
    status_line+="  repo:${REPO_MANIFEST_BRANCH:-?}"
  fi
  printf '%s' "$status_line"
}

_draw_separator() {
  printf '\e[%d;1H\e[2K' "$1"
  local i
  if [[ "$1" -eq 3 && "$SCANNED" -lt "$TOTAL" && "$TOTAL" -gt 0 ]]; then
    local fill=$(( TERM_COLS * SCANNED / TOTAL ))
    for ((i=0; i<TERM_COLS; i++)); do
      [[ "$i" -lt "$fill" ]] && printf '\e[32m▓\e[0m' || printf -- '-'
    done
  else
    for ((i=0; i<TERM_COLS; i++)); do printf -- '-'; done
  fi
}

_rebuild_view() {
  VIEW=()
  local i line
  for i in "${!ROWS[@]}"; do
    line="${ROWS[$i]}"
    if [[ -n "$FILTER" ]]; then
      [[ "$line" == *"$FILTER"* ]] || continue
    fi
    VIEW+=("$i")
  done
  _sort_view
  local max=$(( ${#VIEW[@]} - 1 ))
  [[ "$max" -lt 0 ]] && max=0
  [[ "$SELECTED" -gt "$max" ]] && SELECTED="$max"
  [[ "$SELECTED" -lt 0 ]] && SELECTED=0
}

_sort_view() {
  [[ "$SORT_MODE" == "path" ]] && return
  [[ "${#VIEW[@]}" -eq 0 ]] && return
  local -a pairs=()
  local i idx repo branch sha date ah bh dirty status rank
  for i in "${!VIEW[@]}"; do
    idx="${VIEW[$i]}"
    IFS=$'\t' read -r repo branch sha date ah bh dirty status _ _ _ <<< "${ROWS[$idx]}"
    case "$SORT_MODE" in
      status)
        case "$status" in
          diverged)    rank=0 ;;
          behind)      rank=1 ;;
          ahead)       rank=2 ;;
          no-upstream) rank=4 ;;
          up-to-date)  rank=5 ;;
          *)           rank=3 ;;
        esac
        [[ "$dirty" == "dirty" && "$rank" -gt 3 ]] && rank=3
        pairs+=("${rank}:${i}") ;;
      date)        pairs+=("${date}:${i}") ;;
      branch)      pairs+=("${branch}:${i}") ;;
      ahead-desc)  pairs+=("$(printf '%05d' $(( 99999 - ah ))):${i}") ;;
      behind-desc) pairs+=("$(printf '%05d' $(( 99999 - bh ))):${i}") ;;
    esac
  done
  local -a orig_view=("${VIEW[@]}")
  VIEW=()
  while IFS=: read -r _ j; do
    VIEW+=("${orig_view[$j]}")
  done < <(printf '%s\n' "${pairs[@]}" | sort)
}

_draw_list() {
  local top=$(( 4 + SHOW_HEADER ))
  local bottom=$(( TERM_ROWS - 2 ))
  local visible=$(( bottom - top + 1 ))
  [[ "$visible" -lt 1 ]] && return

  if [[ "$SELECTED" -lt "$SCROLL" ]]; then SCROLL="$SELECTED"; fi
  if [[ "$SELECTED" -ge $((SCROLL + visible)) ]]; then SCROLL=$((SELECTED - visible + 1)); fi
  [[ "$SCROLL" -lt 0 ]] && SCROLL=0

  local i screen_row idx line repo branch sha _date _ah _bh dirty status _stash
  local maxrepo=$(( TERM_COLS - 55 ))
  [[ "$maxrepo" -lt 20 ]] && maxrepo=20

  if [[ "$SHOW_HEADER" -eq 1 ]]; then
    printf '\e[4;1H\e[2K\e[2m  %-*s  %-14s  %-8s  %-11s  %-5s  +A/-B\e[0m' \
      "$maxrepo" "REPO" "BRANCH" "SHA" "STATUS" "DIRTY"
  fi

  for ((i=0; i<visible; i++)); do
    screen_row=$((top + i))
    printf '\e[%d;1H\e[2K' "$screen_row"
    idx=$((SCROLL + i))
    [[ "$idx" -ge "${#VIEW[@]}" ]] && continue
    line="${ROWS[${VIEW[$idx]}]}"
    IFS=$'\t' read -r repo branch sha _date _ah _bh dirty status _ _ _stash <<< "$line"

    local marker="  "
    [[ "$idx" -eq "$SELECTED" ]] && marker=$'\e[1;7m> \e[0m'

    local color="\e[32m"
    case "$status" in
      up-to-date) color="\e[32m" ;;
      behind)     color="\e[33m" ;;
      ahead)      color="\e[36m" ;;
      diverged)   color="\e[31m" ;;
      dirty)      color="\e[31m" ;;
      no-upstream)color="\e[90m" ;;
    esac
    local dirty_color="\e[32m"
    [[ "$dirty" == "dirty" ]] && dirty_color="\e[31m"

    local shortrepo="$repo"
    if [[ "${#shortrepo}" -gt "$maxrepo" ]]; then
      shortrepo="…${shortrepo: -$((maxrepo-1))}"
    fi
    printf '%b%-*s  %-14s  %-8s  %b%-11s\e[0m  %b%-5s\e[0m  +%s/-%s' \
      "$marker" "$maxrepo" "$shortrepo" "$branch" "$sha" \
      "$color" "$status" "$dirty_color" "$dirty" "$_ah" "$_bh"
    if [[ "${_stash:-0}" -gt 0 ]]; then
      printf ' \e[33ms:%s\e[0m' "$_stash"
    fi
  done
}

_draw_help() {
  local row=$(( TERM_ROWS - 1 ))
  _draw_separator "$row"
  row=$((row + 1))
  if [[ "$FILTER_MODE" -eq 1 ]]; then
    printf '\e[%d;1H\e[2K\e[2mfilter:\e[0m %s\e[2m█  (Enter=confirm  Esc=cancel)\e[0m' "$row" "$FILTER_INPUT"
  else
    printf '\e[%d;1H\e[2K\e[2m j/k/g/G move   PgUp/PgDn page   / filter   s sort   f fetch   r rescan   ? help   q quit \e[0m' "$row"
  fi
}

_redraw_all() {
  printf '\e[2J\e[H'
  _query_size
  _draw_ticker
  _draw_status
  _draw_separator 3
  _draw_list
  _draw_help
}

_start_scan() {
  if [[ -n "$SCAN_PID" ]]; then
    kill "$SCAN_PID" 2>/dev/null || true
    wait "$SCAN_PID" 2>/dev/null || true
    SCAN_PID=""
  fi
  exec 3<&- 2>/dev/null || true
  [[ -n "$FIFO" && -e "$FIFO" ]] && rm -f "$FIFO"
  FIFO=$(mktemp -u -t repo-report.fifo.XXXXXX) || err RR403 "mktemp -u failed" 1
  mkfifo "$FIFO" 2>/dev/null || err RR403 "mkfifo failed: $FIFO" 1

  mapfile -t GIT_PATHS < <(scan_paths)
  TOTAL="${#GIT_PATHS[@]}"
  ROWS=(); VIEW=(); SELECTED=0; SCROLL=0
  SCANNED=0; BEHIND_N=0; DIRTY_N=0; DIVERGED_N=0; AHEAD_N=0
  BREAKING=""

  export REPO_REPORT_FETCH="$FETCH"
  if [[ "$TOTAL" -gt 0 ]]; then
    ( printf '%s\0' "${GIT_PATHS[@]}" \
        | xargs -0 -n1 -P "$JOBS" bash -c '_report_one "$1"' bash > "$FIFO"
    ) &
    SCAN_PID=$!
  fi
  exec 3< "$FIFO"
}

_absorb_line() {
  local line="$1"
  [[ -z "$line" ]] && return
  ROWS+=("$line")
  SCANNED=$(( SCANNED + 1 ))
  local repo _b _s _d _a _bh dirty status _stash
  IFS=$'\t' read -r repo _b _s _d _a _bh dirty status _ _ _stash <<< "$line"
  local short="${repo##*/}"
  case "$status" in
    behind)   ((BEHIND_N++));   _add_breaking "⚡ ${short} BEHIND" ;;
    ahead)    ((AHEAD_N++));    _add_breaking "⚡ ${short} AHEAD" ;;
    diverged) ((DIVERGED_N++)); _add_breaking "⚡ ${short} DIVERGED" ;;
  esac
  [[ "$dirty" == "dirty" ]] && { ((DIRTY_N++)); _add_breaking "⚠ ${short} DIRTY"; }
}

_drain_scan() {
  local line got=0
  while IFS= read -r -t 0.01 -u 3 line; do
    _absorb_line "$line"
    got=1
    [[ "$got" -ge 50 ]] && break
  done
  [[ "$got" -eq 1 ]] && _rebuild_view
}

_prompt_export() {
  local default_file="/tmp/repo-report-$(date +%Y%m%d).tsv"
  local row="$TERM_ROWS"
  printf '\e[%d;1H\e[2K' "$row"
  printf '\e[?25h'
  stty sane 2>/dev/null || true
  printf 'export to [%s]: ' "$default_file"
  local input
  IFS= read -r input
  stty -echo -icanon time 0 min 0 2>/dev/null || true
  printf '\e[?25l'
  [[ -z "$input" ]] && input="$default_file"
  local tsv_data=""
  local i
  for i in "${VIEW[@]}"; do
    tsv_data+="${ROWS[$i]}"$'\n'
  done
  tsv_data="${tsv_data%$'\n'}"
  local fmt="tsv"
  [[ "$input" == *.json ]] && fmt="json"
  if [[ "$fmt" == "json" ]]; then
    emit_json "$tsv_data" > "$input" 2>/dev/null \
      && _add_breaking "✓ exported ${#VIEW[@]} repos → $input" \
      || _add_breaking "✗ export failed: $input"
  else
    { printf 'repo\tbranch\tsha\tdate\tahead\tbehind\tdirty\tstatus\tremote\tmessage\tstash\n'
      printf '%s\n' "$tsv_data"
    } > "$input" 2>/dev/null \
      && _add_breaking "✓ exported ${#VIEW[@]} repos → $input" \
      || _add_breaking "✗ export failed: $input"
  fi
  _redraw_all
}

_draw_help_overlay() {
  local box_w=46 box_h=31
  local col=$(( (TERM_COLS - box_w) / 2 ))
  local row=$(( (TERM_ROWS - box_h) / 2 ))
  [[ "$col" -lt 1 ]] && col=1
  [[ "$row" -lt 1 ]] && row=1
  local i
  printf '\e[%d;%dH' "$row" "$col"
  printf '\e[7m╭'; for ((i=0;i<box_w-2;i++)); do printf '─'; done; printf '╮\e[0m'
  local -a lines=(
    "  REPO-REPORT  KEY BINDINGS             "
    "                                        "
    "  j / ↓       move down                 "
    "  k / ↑       move up                   "
    "  g / G       jump top / bottom         "
    "  PgDn/PgUp   page scroll               "
    "  /           filter (live, Esc=cancel) "
    "  Esc         clear filter              "
    "  Enter       open detail pane          "
    "  s           cycle sort mode           "
    "  f           toggle fetch + rescan     "
    "  F           repo sync  (AOSP only)    "
    "  r           rescan                    "
    "  T           repo status  (AOSP only)  "
    "  e           export current view       "
    "  c           toggle column header      "
    "  ?           this help                 "
    "  q           quit                      "
    "                                        "
    "  Colours                               "
    "  green    = up-to-date                 "
    "  yellow   = behind                     "
    "  cyan     = ahead                      "
    "  red      = diverged                   "
    "  grey     = no-upstream                "
    "  yellow s:N = stash count              "
    "                                        "
    "        press any key to dismiss        "
  )
  local r=$(( row + 1 ))
  for l in "${lines[@]}"; do
    printf '\e[%d;%dH\e[7m│\e[0m%-*s\e[7m│\e[0m' "$r" "$col" "$(( box_w - 2 ))" "$l"
    (( r++ ))
  done
  printf '\e[%d;%dH\e[7m╰' "$r" "$col"
  for ((i=0;i<box_w-2;i++)); do printf '─'; done
  printf '╯\e[0m'
  read -rsn1 -t 30 _ || true
  _redraw_all
}

_open_detail() {
  [[ "${#VIEW[@]}" -eq 0 ]] && return
  local idx="${VIEW[$SELECTED]}"
  local line="${ROWS[$idx]}"
  local repo branch sha date ah bh dirty status remote msg stash
  IFS=$'\t' read -r repo branch sha date ah bh dirty status remote msg stash <<< "$line"
  local log5 stash_n
  log5=$(git -C "$repo" log -5 --oneline 2>/dev/null || echo "(no log)")
  stash_n=$(git -C "$repo" stash list 2>/dev/null | wc -l | tr -d ' ')
  local box_w=$(( TERM_COLS - 4 ))
  [[ "$box_w" -gt 80 ]] && box_w=80
  local box_h=20
  local col=$(( (TERM_COLS - box_w) / 2 ))
  local row=$(( (TERM_ROWS - box_h) / 2 ))
  [[ "$col" -lt 1 ]] && col=1
  [[ "$row" -lt 1 ]] && row=1
  local i
  printf '\e[%d;%dH' "$row" "$col"
  printf '\e[7m╭'; for ((i=0;i<box_w-2;i++)); do printf '─'; done; printf '╮\e[0m'
  local inner=$(( box_w - 4 ))
  local -a dlines=(
    "$(printf '%-*s' "$inner" " DETAIL: ${repo##*/}")"
    "$(printf '%-*s' "$inner" "")"
    "$(printf '%-*s' "$inner" " repo:    $repo")"
    "$(printf '%-*s' "$inner" " branch:  $branch")"
    "$(printf '%-*s' "$inner" " sha:     $sha")"
    "$(printf '%-*s' "$inner" " date:    $date")"
    "$(printf '%-*s' "$inner" " status:  $status")"
    "$(printf '%-*s' "$inner" " dirty:   $dirty")"
    "$(printf '%-*s' "$inner" " ahead:   $ah  behind: $bh")"
    "$(printf '%-*s' "$inner" " stash:   $stash_n")"
    "$(printf '%-*s' "$inner" " remote:  ${remote:0:$inner}")"
    "$(printf '%-*s' "$inner" " message: ${msg:0:$inner}")"
    "$(printf '%-*s' "$inner" "")"
    "$(printf '%-*s' "$inner" " recent commits:")"
  )
  while IFS= read -r logline; do
    dlines+=("$(printf '%-*s' "$inner" "   ${logline:0:$inner}")")
  done <<< "$log5"
  while [[ "${#dlines[@]}" -lt $(( box_h - 2 )) ]]; do
    dlines+=("$(printf '%-*s' "$inner" "")")
  done
  local r=$(( row + 1 ))
  for l in "${dlines[@]}"; do
    [[ "$r" -ge $(( row + box_h - 1 )) ]] && break
    printf '\e[%d;%dH\e[7m│\e[0m %-*s \e[7m│\e[0m' "$r" "$col" "$inner" "$l"
    (( r++ ))
  done
  printf '\e[%d;%dH\e[7m│\e[0m%-*s\e[7m│\e[0m' "$r" "$col" "$(( box_w - 2 ))" "$(printf '%*s' "$(( box_w - 2 ))" ' press any key to close ')"
  (( r++ ))
  printf '\e[%d;%dH\e[7m╰' "$r" "$col"
  for ((i=0;i<box_w-2;i++)); do printf '─'; done
  printf '╯\e[0m'
  read -rsn1 -t 60 _ || true
  _redraw_all
}

_run_repo_sync() {
  [[ "$IS_REPO_WS" -eq 0 ]] && { _add_breaking "⚠ not an AOSP workspace"; return; }
  command -v repo >/dev/null 2>&1 || { _add_breaking "⚠ repo not found on PATH"; return; }
  _add_breaking "⟳ repo sync starting..."
  ( repo sync -j"$JOBS" -q 2>&1 ) &
  local rpid=$!
  wait "$rpid" 2>/dev/null || true
  _add_breaking "✓ repo sync done"
  _start_scan
  _redraw_all
}

_draw_repo_status_overlay() {
  [[ "$IS_REPO_WS" -eq 0 ]] && { _add_breaking "⚠ not an AOSP workspace"; return; }
  command -v repo >/dev/null 2>&1 || { _add_breaking "⚠ repo not found on PATH"; return; }
  local -a lines=()
  while IFS= read -r l; do lines+=("$l"); done < <(repo status 2>&1)
  local box_w=$(( TERM_COLS - 4 ))
  [[ "$box_w" -gt 100 ]] && box_w=100
  local max_lines=$(( TERM_ROWS - 6 ))
  local box_h=$(( ${#lines[@]} + 4 ))
  [[ "$box_h" -gt "$max_lines" ]] && box_h="$max_lines"
  local col=$(( (TERM_COLS - box_w) / 2 ))
  local row=$(( (TERM_ROWS - box_h) / 2 ))
  [[ "$col" -lt 1 ]] && col=1
  [[ "$row" -lt 1 ]] && row=1
  local i
  printf '\e[%d;%dH' "$row" "$col"
  printf '\e[7m╭'; for ((i=0;i<box_w-2;i++)); do printf '─'; done; printf '╮\e[0m'
  local inner=$(( box_w - 4 ))
  local r=$(( row + 1 ))
  printf '\e[%d;%dH\e[7m│\e[0m %-*s \e[7m│\e[0m' "$r" "$col" "$inner" "repo status"
  (( r++ ))
  printf '\e[%d;%dH\e[7m│\e[0m %-*s \e[7m│\e[0m' "$r" "$col" "$inner" ""
  (( r++ ))
  for l in "${lines[@]}"; do
    [[ "$r" -ge $(( row + box_h - 2 )) ]] && break
    printf '\e[%d;%dH\e[7m│\e[0m %-*s \e[7m│\e[0m' "$r" "$col" "$inner" "${l:0:$inner}"
    (( r++ ))
  done
  while [[ "$r" -lt $(( row + box_h - 2 )) ]]; do
    printf '\e[%d;%dH\e[7m│\e[0m %-*s \e[7m│\e[0m' "$r" "$col" "$inner" ""
    (( r++ ))
  done
  printf '\e[%d;%dH\e[7m│\e[0m%-*s\e[7m│\e[0m' "$r" "$col" "$(( box_w - 2 ))" "$(printf '%*s' "$(( box_w - 2 ))" ' press any key to close ')"
  (( r++ ))
  printf '\e[%d;%dH\e[7m╰' "$r" "$col"
  for ((i=0;i<box_w-2;i++)); do printf '─'; done
  printf '╯\e[0m'
  read -rsn1 -t 60 _ || true
  _redraw_all
}

_tui_main() {
  _tui_setup
  _start_scan
  _redraw_all

  local key seq2 seq3 tick=0
  while true; do
    _drain_scan
    TICKER_OFFSET=$((TICKER_OFFSET + 1))
    _draw_ticker
    _draw_status
    _draw_list

    if [[ "$RESIZE" -eq 1 ]]; then
      RESIZE=0
      _redraw_all
    fi

    if read -rsn1 -t 0.1 key; then
      if [[ "$FILTER_MODE" -eq 1 ]]; then
        case "$key" in
          $'\n')
            FILTER="$FILTER_INPUT"; FILTER_MODE=0; _redraw_all ;;
          $'\e')
            read -rsn1 -t 0.005 seq2 || {
              FILTER="$FILTER_SAVED"; FILTER_INPUT="$FILTER_SAVED"
              FILTER_MODE=0; _rebuild_view; _draw_help; continue
            }
            read -rsn1 -t 0.005 seq3 || true
            ;;
          $'\x7f'|$'\b')
            FILTER_INPUT="${FILTER_INPUT%?}"
            FILTER="$FILTER_INPUT"
            _rebuild_view; _draw_help ;;
          *)
            FILTER_INPUT+="$key"
            FILTER="$FILTER_INPUT"
            _rebuild_view; _draw_help ;;
        esac
      else
        case "$key" in
          q|Q) break ;;
          j)   SELECTED=$((SELECTED + 1)); _rebuild_view ;;
          k)   SELECTED=$((SELECTED - 1)); _rebuild_view ;;
          g)   SELECTED=0; _rebuild_view ;;
          G)   SELECTED=$(( ${#VIEW[@]} - 1 )); [[ "$SELECTED" -lt 0 ]] && SELECTED=0; _rebuild_view ;;
          r)   _start_scan; _redraw_all ;;
          f)   FETCH=$((1 - FETCH)); _start_scan; _redraw_all ;;
          s)   SORT_IDX=$(( (SORT_IDX + 1) % ${#SORT_MODES[@]} ))
               SORT_MODE="${SORT_MODES[$SORT_IDX]}"
               _rebuild_view ;;
          c)   SHOW_HEADER=$(( 1 - SHOW_HEADER )); _redraw_all ;;
          e)   _prompt_export ;;
          '?') _draw_help_overlay ;;
          $'\n') _open_detail ;;
          /)
            FILTER_SAVED="$FILTER"
            FILTER_INPUT="$FILTER"
            FILTER_MODE=1
            _draw_help ;;
          F) _run_repo_sync ;;
          T) _draw_repo_status_overlay ;;
          $'\e')
            read -rsn1 -t 0.005 seq2 || { FILTER=""; _rebuild_view; continue; }
            read -rsn1 -t 0.005 seq3 || continue
            if [[ "$seq2" == "[" ]]; then
              case "$seq3" in
                A) SELECTED=$((SELECTED - 1)); _rebuild_view ;;
                B) SELECTED=$((SELECTED + 1)); _rebuild_view ;;
                5) read -rsn1 -t 0.005 _ || true
                   local pg=$(( TERM_ROWS - 6 )); [[ "$pg" -lt 1 ]] && pg=1
                   SELECTED=$(( SELECTED - pg )); _rebuild_view ;;
                6) read -rsn1 -t 0.005 _ || true
                   local pg=$(( TERM_ROWS - 6 )); [[ "$pg" -lt 1 ]] && pg=1
                   SELECTED=$(( SELECTED + pg )); _rebuild_view ;;
              esac
            fi
            ;;
        esac
      fi
    fi
    tick=$((tick + 1))
  done

  _tui_teardown

  # Use the collected ROWS for final exit code
  local tsv=""
  if [[ "${#ROWS[@]}" -gt 0 ]]; then
    tsv=$(printf '%s\n' "${ROWS[@]}")
  fi
  if final_exit_code "$tsv"; then exit 0; else exit 1; fi
}

_tui_main
